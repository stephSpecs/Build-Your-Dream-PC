{
  "name": "pc-builder",
  "version": "1.0.0",
  "description": "DIY PC Customizer",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "setup-db": "node server/config/reset.js"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.0"
  }
}
